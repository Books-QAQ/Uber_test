APP_ENV=local
HTTP_ADDR=:8080
UDP_ADDR=:9000
AUTH_JWT_SECRET=dev-secret-change-me
AUTH_TOKEN_TTL=24h
MYSQL_ENABLED=false
MYSQL_DSN=root:root@tcp(127.0.0.1:3306)/uber_test?parseTime=true
MYSQL_MAX_OPEN_CONNS=10
MYSQL_MAX_IDLE_CONNS=5
MYSQL_CONN_MAX_LIFETIME=1h
WS_READ_BUFFER=1024
WS_WRITE_BUFFER=1024
RECENT_LOCATION_LIMIT=20
REDIS_ENABLED=false
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=uber-test
REDIS_LOCATION_TTL=24h
SHUTDOWN_TIMEOUT=10s
